@model IEnumerable<FoodSafetyTracker.Web.Models.FollowUp>

@{
    ViewData["Title"] = "Follow-Ups";
}

<h2>Follow-Ups</h2>

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <p><a asp-action="Create" class="btn btn-primary">Add New Follow-Up</a></p>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Premises</th>
            <th>Inspection Date</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Closed Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var isOverdue = item.Status == FoodSafetyTracker.Web.Models.FollowUpStatus.Open && item.DueDate < DateTime.Now;
            <tr class="@(isOverdue ? "table-danger" : "")">
                <td>@item.Inspection.Premises.Name</td>
                <td>@item.Inspection.InspectionDate.ToShortDateString()</td>
                <td>@item.DueDate.ToShortDateString()</td>
                <td>
                    @if (isOverdue)
                    {
                        <span class="badge bg-danger">⚠️ Overdue</span>
                    }
                    else if (item.Status == FoodSafetyTracker.Web.Models.FollowUpStatus.Open)
                    {
                        <span class="badge bg-warning">🟡 Open</span>
                    }
                    else
                    {
                        <span class="badge bg-success">✅ Closed</span>
                    }
                </td>
                <td>@(item.ClosedDate.HasValue ? item.ClosedDate.Value.ToShortDateString() : "-")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>