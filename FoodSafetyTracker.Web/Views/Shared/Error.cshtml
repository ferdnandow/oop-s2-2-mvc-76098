@model Microsoft.AspNetCore.Mvc.ProblemDetails
@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="alert alert-danger">
        <h2>⚠️ Something went wrong</h2>
        <p>We're sorry, an unexpected error occurred. Please try again or contact support.</p>
    </div>
    @if (System.Diagnostics.Debugger.IsAttached)
    {
        <div class="alert alert-warning">
            <h4>Debug Info</h4>
            <p><strong>Request ID:</strong> @System.Diagnostics.Activity.Current?.Id ?? HttpContext.TraceIdentifier</p>
        </div>
    }
    <a href="/" class="btn btn-primary">Go to Home</a>
</div>