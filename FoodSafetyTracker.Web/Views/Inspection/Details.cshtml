@model FoodSafetyTracker.Web.Models.Inspection

@{
    ViewData["Title"] = "Inspection Details";
}

<h2>Inspection Details</h2>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Premises</dt>
            <dd class="col-sm-9">@Model.Premises.Name</dd>
            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.InspectionDate.ToShortDateString()</dd>
            <dt class="col-sm-3">Score</dt>
            <dd class="col-sm-9">@Model.Score / 100</dd>
            <dt class="col-sm-3">Outcome</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Outcome == FoodSafetyTracker.Web.Models.Outcome.Pass ? "bg-success" : "bg-danger")">
                    @Model.Outcome
                </span>
            </dd>
            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@Model.Notes</dd>
        </dl>
    </div>
</div>

<h4>Follow-Ups</h4>
@if (Model.FollowUps.Any())
{
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Due Date</th>
                <th>Status</th>
                <th>Closed Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var followUp in Model.FollowUps)
            {
                <tr>
                    <td>@followUp.DueDate.ToShortDateString()</td>
                    <td>
                        <span class="badge @(followUp.Status == FoodSafetyTracker.Web.Models.FollowUpStatus.Open ? "bg-warning" : "bg-success")">
                            @followUp.Status
                        </span>
                    </td>
                    <td>@(followUp.ClosedDate.HasValue ? followUp.ClosedDate.Value.ToShortDateString() : "-")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No follow-ups recorded.</p>
}

<div class="mt-3">
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>