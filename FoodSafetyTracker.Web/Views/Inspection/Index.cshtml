@model IEnumerable<FoodSafetyTracker.Web.Models.Inspection>

@{
    ViewData["Title"] = "Inspections";
}

<h2>Inspections</h2>

@if (TempData["AutoFollowUp"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["AutoFollowUp"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <p><a asp-action="Create" class="btn btn-primary">Add New Inspection</a></p>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Premises</th>
            <th>Date</th>
            <th>Score</th>
            <th>Outcome</th>
            <th>Notes</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Premises.Name</td>
                <td>@item.InspectionDate.ToShortDateString()</td>
                <td>@item.Score</td>
                <td>
                    <span class="badge @(item.Outcome == FoodSafetyTracker.Web.Models.Outcome.Pass ? "bg-success" : "bg-danger")">
                        @item.Outcome
                    </span>
                </td>
                <td>@item.Notes</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>