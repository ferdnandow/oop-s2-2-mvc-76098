@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>

@{
    ViewData["Title"] = "Users";
}

<h2>👥 Users</h2>

<p><a asp-action="Create" class="btn btn-primary">Add New User</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Email</th>
            <th>Role</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>
                    @if (ViewBag.UserRoles.ContainsKey(user.Id))
                    {
                        foreach (var role in ViewBag.UserRoles[user.Id])
                        {
                            <span class="badge bg-primary">@role</span>
                        }
                    }
                </td>
                <td>
                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>