@{
    ViewData["Title"] = "Dashboard";
}

<h2>📊 Dashboard</h2>

<form method="get" asp-action="Index" class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label">Filter by Town</label>
        <select name="town" class="form-select">
            <option value="">-- All Towns --</option>
            @foreach (var town in ViewBag.Towns)
            {
                <option value="@town.Text" selected="@(ViewBag.SelectedTown == town.Text)">@town.Text</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Filter by Risk Rating</label>
        <select name="riskRating" class="form-select">
            <option value="">-- All Risk Ratings --</option>
            @foreach (var rating in Html.GetEnumSelectList<FoodSafetyTracker.Web.Models.RiskRating>())
            {
                <option value="@rating.Value" selected="@(ViewBag.SelectedRiskRating != null && ViewBag.SelectedRiskRating.ToString() == rating.Text)">@rating.Text</option>
            }
        </select>
    </div>
    <div class="col-md-4 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">Apply Filters</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<div class="row">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-header">Inspections This Month</div>
            <div class="card-body">
                <h1 class="card-title display-4">@ViewBag.InspectionsThisMonth</h1>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger mb-3">
            <div class="card-header">Failed Inspections This Month</div>
            <div class="card-body">
                <h1 class="card-title display-4">@ViewBag.FailedInspectionsThisMonth</h1>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning mb-3">
            <div class="card-header">Overdue Follow-Ups</div>
            <div class="card-body">
                <h1 class="card-title display-4">@ViewBag.OverdueFollowUps</h1>
            </div>
        </div>
    </div>
</div>

<h4 class="mt-4">📈 Pass vs Fail (Last 6 Months)</h4>
<canvas id="inspectionChart" height="100"></canvas>

<h4 class="mt-4">🕐 Recent Inspections</h4>
<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Premises</th>
            <th>Town</th>
            <th>Date</th>
            <th>Score</th>
            <th>Outcome</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var inspection in ViewBag.RecentInspections)
        {
            <tr>
                <td>@inspection.Premises.Name</td>
                <td>@inspection.Premises.Town</td>
                <td>@inspection.InspectionDate.ToShortDateString()</td>
                <td>@inspection.Score</td>
                <td>
                    <span class="badge @(inspection.Outcome == FoodSafetyTracker.Web.Models.Outcome.Pass ? "bg-success" : "bg-danger")">
                        @inspection.Outcome
                    </span>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-controller="Premises" asp-action="Index" class="btn btn-outline-primary me-2">View Premises</a>
    <a asp-controller="Inspection" asp-action="Index" class="btn btn-outline-primary me-2">View Inspections</a>
    <a asp-controller="FollowUp" asp-action="Index" class="btn btn-outline-primary">View Follow-Ups</a>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var ctx = document.getElementById('inspectionChart').getContext('2d');
        var chart = new Chart(ctx, {
        type: 'bar',
        data: {
        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartLabels)),
        datasets: [
        {
        label: 'Pass',
        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PassData)),
        backgroundColor: 'rgba(40, 167, 69, 0.7)'
        },
        {
        label: 'Fail',
        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.FailData)),
        backgroundColor: 'rgba(220, 53, 69, 0.7)'
        }
        ]
        },
        options: {
        responsive: true,
        scales: {
        y: { beginAtZero: true }
        }
        }
        });
    </script>
}